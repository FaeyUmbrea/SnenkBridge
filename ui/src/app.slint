import { ComboBox } from "std-widgets.slint";

component StyledInput inherits Rectangle {
    in property<string> placeholder;
    in-out property<string> text <=> input.text;
    in property<bool> enabled: true;
    in property<bool> round-right: true;
    in property<bool> round-left: true;

    callback edited(string);

    border-top-left-radius: root.round-left ? 6px : 0;
    border-bottom-left-radius: root.round-left ? 6px : 0;
    border-top-right-radius: root.round-right ? 6px : 0;
    border-bottom-right-radius: root.round-right ? 6px : 0;
    border-width: 1px;
    border-color: root.enabled ? (input.has-focus ? #6c6cb5 : #444466) : #2d2d44;
    background: root.enabled ? #141426 : #161628;
    height: 34px;

    input := TextInput {
        x: 10px;
        y: 0;
        width: parent.width - 20px;
        height: parent.height;
        vertical-alignment: center;
        color: root.enabled ? #d4d4e8 : #555570;
        font-size: 13px;
        enabled: root.enabled;
        edited => { root.edited(self.text); }
    }

    if input.text == "" : Text {
        x: 10px;
        vertical-alignment: center;
        color: #4a4a6a;
        font-size: 13px;
        text: root.placeholder;
    }
}

component Btn inherits Rectangle {
    in property<string> label;
    in property<bool> enabled: true;
    in property<color> base-bg: #3d3d6b;
    in property<color> hover-bg: #4d4d80;
    in property<color> base-border: #4a4a7a;
    in property<color> hover-border: #6c6cb5;
    in property<color> text-color: #c8c8e0;
    in property<bool> round-left: true;
    in property<bool> round-right: true;

    callback clicked;

    border-top-left-radius: root.round-left ? 6px : 0;
    border-bottom-left-radius: root.round-left ? 6px : 0;
    border-top-right-radius: root.round-right ? 6px : 0;
    border-bottom-right-radius: root.round-right ? 6px : 0;
    border-width: 1px;
    border-color: touch.has-hover && root.enabled ? root.hover-border : root.base-border;
    background: touch.has-hover && root.enabled ? root.hover-bg : root.base-bg;
    height: 34px;
    opacity: root.enabled ? 1.0 : 0.4;

    touch := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }

    Text {
        text: root.label;
        color: root.text-color;
        font-size: 13px;
        font-weight: 500;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component FieldLabel inherits Text {
    color: #8888aa;
    font-size: 12px;
    vertical-alignment: center;
    min-width: 62px;
}

component UnitLabel inherits Text {
    color: #555570;
    font-size: 12px;
    vertical-alignment: center;
}

component StatusBadge inherits HorizontalLayout {
    in property<color> dot-color: #555570;
    in property<string> label: "Disconnected";

    spacing: 5px;
    alignment: center;

    Rectangle {
        width: 7px;
        height: 7px;
        border-radius: 3.5px;
        background: root.dot-color;
    }

    Text {
        text: root.label;
        color: root.dot-color;
        font-size: 11px;
        vertical-alignment: center;
    }
}

component Card inherits Rectangle {
    background: #1e1e30;
    border-radius: 10px;
    border-width: 1px;
    border-color: #2a2a44;

    VerticalLayout {
        padding: 14px;
        spacing: 8px;

        @children
    }
}

component StyledCombo inherits ComboBox {
    height: 34px;
}

export component App inherits Window {
    title: "SnenkBridge";
    default-font-family: "Inter, SF Pro, Segoe UI, sans-serif";
    default-font-size: 13px;
    min-width: 480px;
    min-height: 380px;
    preferred-width: 480px;
    preferred-height: 380px;
    background: #141422;

    in-out property<bool> show-about: false;
    in-out property<string> about-text;
    in-out property<int> preset-index: 0;
    in-out property<string> phone-ip: "127.0.0.1";
    in-out property<int> tracking-type-index: 0;
    in-out property<string> face-search-timeout: "3000";
    in-out property<string> vts-ip: "localhost";
    in-out property<string> vts-port: "8001";

    in-out property<bool> source-active: false;
    in-out property<bool> target-active: false;
    in-out property<string> source-status: "Disconnected";
    in-out property<color> source-status-color: #cc4444;
    in-out property<string> target-status: "Disconnected";
    in-out property<color> target-status-color: #cc4444;
    in-out property<string> error-text;
    in-out property<bool> has-custom-preset: false;

    callback import-preset();
    callback toggle-source();
    callback toggle-target();
    callback settings-changed();

    VerticalLayout {
        padding: 12px;
        spacing: 10px;

        // ── Header ──
        HorizontalLayout {
            alignment: space-between;
            Text {
                text: "SnenkBridge";
                color: #8888bb;
                font-size: 14px;
                font-weight: 700;
                vertical-alignment: center;
            }
            Rectangle {
                width: about-touch.has-hover ? 46px : 44px;
                height: 20px;
                about-touch := TouchArea {
                    clicked => { root.show-about = !root.show-about; }
                }
                Text {
                    text: "About";
                    color: about-touch.has-hover ? #8888bb : #555570;
                    font-size: 11px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        // ── Source card ──
        Card {
            // Header row: title + status badge
            HorizontalLayout {
                alignment: space-between;
                Text {
                    text: "SOURCE";
                    color: #6c6cb5;
                    font-size: 11px;
                    font-weight: 700;
                    letter-spacing: 0.8px;
                    vertical-alignment: center;
                }
                StatusBadge {
                    dot-color: root.source-status-color;
                    label: root.source-status;
                }
            }

            HorizontalLayout {
                spacing: 10px;
                FieldLabel { text: "Phone IP"; }
                StyledInput {
                    placeholder: "192.168.1.71";
                    text <=> root.phone-ip;
                    enabled: !root.source-active;
                    horizontal-stretch: 1;
                    edited(val) => { root.settings-changed(); }
                }
            }

            HorizontalLayout {
                spacing: 10px;
                FieldLabel { text: "Tracking"; }
                StyledCombo {
                    model: ["VTubeStudio", "IFacialMocap"];
                    current-index <=> root.tracking-type-index;
                    enabled: !root.source-active;
                    width: 160px;
                    selected(val) => { root.settings-changed(); }
                }
                Rectangle { horizontal-stretch: 1; }
                FieldLabel { text: "Timeout"; min-width: 0; }
                StyledInput {
                    placeholder: "3000";
                    text <=> root.face-search-timeout;
                    enabled: !root.source-active;
                    width: 64px;
                    edited(val) => { root.settings-changed(); }
                }
                UnitLabel { text: "ms"; }
            }

            // Button row — right-aligned
            HorizontalLayout {
                alignment: end;
                if !root.source-active : Btn {
                    label: "Connect";
                    base-bg: #4a4a8a;
                    hover-bg: #5c5ca0;
                    base-border: #6c6cb5;
                    hover-border: #8888dd;
                    text-color: #e0e0ff;
                    width: 100px;
                    clicked => { root.toggle-source(); }
                }
                if root.source-active : Btn {
                    label: "Disconnect";
                    base-bg: #6b2a2a;
                    hover-bg: #883838;
                    base-border: #994444;
                    hover-border: #bb5555;
                    text-color: #ffcccc;
                    width: 100px;
                    clicked => { root.toggle-source(); }
                }
            }
        }

        // ── Target card ──
        Card {
            // Header row: title + status badge
            HorizontalLayout {
                alignment: space-between;
                Text {
                    text: "TARGET";
                    color: #6c6cb5;
                    font-size: 11px;
                    font-weight: 700;
                    letter-spacing: 0.8px;
                    vertical-alignment: center;
                }
                StatusBadge {
                    dot-color: root.target-status-color;
                    label: root.target-status;
                }
            }

            // Preset selector + import
            HorizontalLayout {
                spacing: 0;
                FieldLabel { text: "Preset"; }
                StyledCombo {
                    model: root.has-custom-preset
                        ? ["Default", "Maruseu VBridger", "Maruseu Enhanced", "Custom"]
                        : ["Default", "Maruseu VBridger", "Maruseu Enhanced"];
                    current-index <=> root.preset-index;
                    enabled: !root.target-active;
                    horizontal-stretch: 1;
                    selected(val) => { root.settings-changed(); }
                }
                Btn {
                    label: "Import";
                    enabled: !root.target-active;
                    width: 72px;
                    round-left: false;
                    base-bg: #2a2a48;
                    hover-bg: #3a3a5c;
                    base-border: #3d3d5c;
                    hover-border: #6c6cb5;
                    clicked => { root.import-preset(); }
                }
            }

            HorizontalLayout {
                spacing: 10px;
                FieldLabel { text: "VTS IP"; }
                StyledInput {
                    placeholder: "localhost";
                    text <=> root.vts-ip;
                    enabled: !root.target-active;
                    horizontal-stretch: 1;
                    edited(val) => { root.settings-changed(); }
                }
                FieldLabel { text: "Port"; min-width: 0; }
                StyledInput {
                    placeholder: "8001";
                    text <=> root.vts-port;
                    enabled: !root.target-active;
                    width: 64px;
                    edited(val) => { root.settings-changed(); }
                }
            }

            // Button row — right-aligned
            HorizontalLayout {
                alignment: end;
                if !root.target-active : Btn {
                    label: "Connect";
                    base-bg: #4a4a8a;
                    hover-bg: #5c5ca0;
                    base-border: #6c6cb5;
                    hover-border: #8888dd;
                    text-color: #e0e0ff;
                    width: 100px;
                    clicked => { root.toggle-target(); }
                }
                if root.target-active : Btn {
                    label: "Disconnect";
                    base-bg: #6b2a2a;
                    hover-bg: #883838;
                    base-border: #994444;
                    hover-border: #bb5555;
                    text-color: #ffcccc;
                    width: 100px;
                    clicked => { root.toggle-target(); }
                }
            }
        }

        // Error
        if root.error-text != "" : Text {
            text: root.error-text;
            color: #e05a5a;
            font-size: 12px;
            horizontal-alignment: center;
        }
    }

    // ── About overlay ──
    if root.show-about : Rectangle {
        background: #141422ee;
        TouchArea {
            clicked => { root.show-about = false; }
        }

        Card {
            x: 24px;
            y: 24px;
            width: parent.width - 48px;
            height: parent.height - 48px;

            VerticalLayout {
                padding: 0;
                spacing: 10px;

                HorizontalLayout {
                    alignment: space-between;
                    Text {
                        text: "About SnenkBridge";
                        color: #c8c8e0;
                        font-size: 15px;
                        font-weight: 700;
                        vertical-alignment: center;
                    }
                    Btn {
                        label: "X";
                        width: 28px;
                        height: 28px;
                        base-bg: #2a2a48;
                        hover-bg: #6b2a2a;
                        base-border: #3d3d5c;
                        hover-border: #994444;
                        clicked => { root.show-about = false; }
                    }
                }

                Flickable {
                    viewport-height: about-content.preferred-height;
                    about-content := VerticalLayout {
                        spacing: 12px;

                        Text {
                            text: "github.com/FaeyUmbrea/SnenkBridge";
                            color: #6c6cb5;
                            font-size: 12px;
                            wrap: word-wrap;
                        }

                        Text {
                            text: "Presets";
                            color: #8888aa;
                            font-size: 12px;
                            font-weight: 700;
                        }
                        Text {
                            text: "Maruseu VBridger and Maruseu Enhanced presets based on presets by Maruseu (github.com/maruseu/VitaminsPresets), included with permission. These presets are not covered by the project's GPL license.";
                            color: #777799;
                            font-size: 11px;
                            wrap: word-wrap;
                        }

                        Text {
                            text: "Dependencies";
                            color: #8888aa;
                            font-size: 12px;
                            font-weight: 700;
                        }
                        Text {
                            text: root.about-text;
                            color: #555570;
                            font-size: 10px;
                            wrap: word-wrap;
                        }
                    }
                }
            }
        }
    }
}
